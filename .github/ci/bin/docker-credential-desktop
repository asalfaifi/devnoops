#!/usr/bin/env bash
set -Eeuo pipefail

case "${1:-}" in
  get)
    IFS= read -r _ || true
    printf 'credentials not found in native keychain\n' >&2
    exit 1
    ;;
  list)
    printf '{}\n'
    ;;
  store|erase)
    exit 0
    ;;
  *)
    printf 'unsupported credential-helper operation\n' >&2
    exit 1
    ;;
esac
